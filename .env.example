# ─────────────────────────────────────────────────────────────────────────────
# VIRUNGA EXPEDITION TOURS — Environment Variables Reference
# Copy this file to .env.local for local development.
# For production builds, set these via your hosting/CI environment.
# NEVER commit real env files to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase (client-side, safe to expose) ───────────────────────────────────
# These values identify the Firebase project in the browser.
# They are public configuration, not private credentials, but should still be
# supplied via environment variables rather than hardcoded in scripts.
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Emulator toggle ───────────────────────────────────────────────────────────
# Set to "true" only in local development when the Firebase emulators are running.
# Keep this "false" for preview/production builds.
VITE_USE_FIREBASE_EMULATORS=false

# ── Supabase (legacy — to be removed) ────────────────────────────────────────
# These are only kept for reference. The project has migrated to Firebase.
# Remove once src/integrations/supabase/ is deleted.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id

# ── Server-side and script-only variables ────────────────────────────────────
# These are NOT browser variables. Use them only in local server/script envs
# or in your hosting secrets manager / CI secrets.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_ADMIN_EMAIL=admin@example.com
FIREBASE_ADMIN_PASSWORD=your_admin_password
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
RESEND_API_KEY=re_placeholder
LOVABLE_API_KEY=lvbl_placeholder
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
