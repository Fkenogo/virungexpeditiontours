# ─────────────────────────────────────────────────────────────────────────────
# VIRUNGA EXPEDITION TOURS — Environment Variables Reference
# Copy this file to .env for local development.
# For production builds, set these via your hosting/CI environment.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase (client-side, safe to expose) ───────────────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Emulator toggle ───────────────────────────────────────────────────────────
# Set to "true" for local development with Firebase Emulators.
# MUST be "false" (or absent) in production — setting this to "true" in
# production will cause the entire app to fail as it connects to localhost.
VITE_USE_FIREBASE_EMULATORS=true

# ── Supabase (legacy — to be removed) ────────────────────────────────────────
# These are only kept for reference. The project has migrated to Firebase.
# Remove once src/integrations/supabase/ is deleted.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id

# ── Cloud Functions (server-side secrets — set via Firebase config) ───────────
# These are NOT Vite env vars. Set them via:
#   firebase functions:secrets:set RESEND_API_KEY
#   firebase functions:secrets:set LOVABLE_API_KEY
# Or for Functions v1 config:
#   firebase functions:config:set resend.api_key="your_key" lovable.api_key="your_key"
#
# RESEND_API_KEY     — from resend.com dashboard (Emails > API Keys)
# LOVABLE_API_KEY    — from your Lovable AI gateway account
